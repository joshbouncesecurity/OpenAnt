<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{.Title}}</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        navy: {
                            900: '#1a1a2e',
                            800: '#16213e',
                            700: '#0f3460',
                        },
                        accent: '#e94560',
                    }
                }
            }
        }
    </script>
    <style>
        /* Details marker styling */
        details > summary { cursor: pointer; list-style: none; }
        details > summary::-webkit-details-marker { display: none; }
        details > summary::before {
            content: '\25B6';
            display: inline-block;
            margin-right: 0.5rem;
            font-size: 0.7em;
            transition: transform 0.2s ease;
        }
        details[open] > summary::before {
            transform: rotate(90deg);
        }
        /* Remediation section: visual separation for priority groups */
        .remediation-content h3 { margin-top: 1.5rem; }
        .remediation-content h4 {
            margin-top: 1.75rem;
            padding-top: 1rem;
            border-top: 1px solid rgba(255,255,255,0.1);
        }
        .remediation-content h4:first-child { border-top: none; margin-top: 0; padding-top: 0; }
        /* Finding reference links */
        .finding-ref {
            color: #e94560;
            text-decoration: underline;
            text-decoration-color: rgba(233, 69, 96, 0.3);
            text-underline-offset: 2px;
            font-weight: 600;
            font-size: 0.85em;
        }
        .finding-ref:hover {
            text-decoration-color: #e94560;
        }
    </style>
</head>
<body class="bg-navy-900 text-gray-100 font-sans leading-relaxed">

    <!-- Section Nav Bar -->
    <nav class="sticky top-0 z-50 bg-navy-900/95 backdrop-blur border-b border-gray-700/50">
        <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 flex items-center gap-6 overflow-x-auto text-sm py-3">
            <a href="#overview" class="text-gray-400 hover:text-accent whitespace-nowrap transition-colors">Overview</a>
            <a href="#distribution" class="text-gray-400 hover:text-accent whitespace-nowrap transition-colors">Distribution</a>
            <a href="#remediation" class="text-gray-400 hover:text-accent whitespace-nowrap transition-colors">Remediation</a>
            {{if .HasStepReports}}<a href="#pipeline" class="text-gray-400 hover:text-accent whitespace-nowrap transition-colors">Pipeline</a>{{end}}
            {{if .HasFindings}}<a href="#findings" class="text-gray-400 hover:text-accent whitespace-nowrap transition-colors">Findings</a>{{end}}
        </div>
    </nav>

    <main class="max-w-[1400px] mx-auto p-4 sm:p-6 lg:p-8">

        <!-- Header -->
        <header id="overview" class="mb-10 sm:mb-12 pb-6 sm:pb-8 border-b border-gray-700">
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
                <div>
                    <h1 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-accent mb-1">{{.Title}}</h1>
                    <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-gray-400 mt-2">
                        {{if .RepoName}}<span title="Repository"><strong class="text-gray-100">{{.RepoName}}</strong></span>{{end}}
                        {{if .ShortCommit}}<code class="text-xs bg-navy-900 px-2 py-0.5 rounded text-gray-200">{{.ShortCommit}}</code>{{end}}
                        {{if .Language}}<span class="capitalize">{{.Language}}</span>{{end}}
                    </div>
                </div>
                <div class="flex flex-col items-start sm:items-end gap-1 text-sm text-gray-400 shrink-0">
                    {{if .FormatDuration}}<span class="text-gray-100 font-semibold text-base">{{.FormatDuration}}</span>{{end}}
                    <span>{{.Timestamp}}</span>
                    <span>Powered by <a href="https://knostic.ai" target="_blank" rel="noopener" class="text-accent font-semibold hover:text-red-400 transition-colors">Knostic</a></span>
                </div>
            </div>
        </header>

        <!-- Stats Cards -->
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-3 sm:gap-4 mb-8">
            <div class="bg-navy-700 rounded-lg p-4 sm:p-6 text-center">
                <div class="text-2xl sm:text-3xl font-bold">{{.Stats.TotalUnits}}</div>
                <div class="text-gray-300 text-xs sm:text-sm mt-1">Code Units</div>
            </div>
            <div class="bg-navy-700 rounded-lg p-4 sm:p-6 text-center">
                <div class="text-2xl sm:text-3xl font-bold">{{.Stats.TotalFiles}}</div>
                <div class="text-gray-300 text-xs sm:text-sm mt-1">Files</div>
            </div>
            <div class="bg-navy-700 rounded-lg p-4 sm:p-6 text-center">
                <div class="text-2xl sm:text-3xl font-bold text-red-500">{{.Stats.Vulnerable}}</div>
                <div class="text-gray-300 text-xs sm:text-sm mt-1">Vulnerable Units</div>
            </div>
            <div class="bg-navy-700 rounded-lg p-4 sm:p-6 text-center">
                <div class="text-2xl sm:text-3xl font-bold text-orange-500">{{.Stats.Bypassable}}</div>
                <div class="text-gray-300 text-xs sm:text-sm mt-1">Bypassable Units</div>
            </div>
            <div class="bg-navy-700 rounded-lg p-4 sm:p-6 text-center">
                <div class="text-2xl sm:text-3xl font-bold text-green-500">{{.Stats.Secure}}</div>
                <div class="text-gray-300 text-xs sm:text-sm mt-1">Secure Units</div>
            </div>
        </div>

        <!-- Distribution Overview -->
        <section id="distribution" class="mb-10 border-l-4 border-accent pl-4 sm:pl-6">
            <h2 class="text-xl sm:text-2xl font-semibold mb-6">Distribution Overview</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 sm:gap-6 mb-6">
                <div class="bg-navy-800 rounded-lg p-4 sm:p-6">
                    <h3 class="text-center text-gray-300 mb-4 text-sm sm:text-base">By Code Unit</h3>
                    <div class="max-w-full sm:max-w-[350px] mx-auto">
                        <canvas id="unitChart" aria-label="Pie chart showing verdict distribution by code unit" role="img"></canvas>
                    </div>
                </div>
                <div class="bg-navy-800 rounded-lg p-4 sm:p-6">
                    <h3 class="text-center text-gray-300 mb-4 text-sm sm:text-base">By File (Worst Verdict)</h3>
                    <div class="max-w-full sm:max-w-[350px] mx-auto">
                        <canvas id="fileChart" aria-label="Pie chart showing verdict distribution by file" role="img"></canvas>
                    </div>
                </div>
            </div>

            <!-- Category Legend -->
            <details open class="bg-navy-800 rounded-lg">
                <summary class="px-4 sm:px-6 py-3 text-gray-300 font-medium text-sm sm:text-base hover:text-gray-100 transition-colors">
                    Verdict Categories
                </summary>
                <div class="px-4 sm:px-6 pb-4">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="border-b border-gray-700">
                                <th class="text-left py-3 px-4 text-gray-300 font-medium">Category</th>
                                <th class="text-left py-3 px-4 text-gray-300 font-medium">Description</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{range $i, $cat := .Categories}}
                            <tr class="border-b border-gray-800 {{if even $i}}bg-navy-800{{else}}bg-navy-900/30{{end}}">
                                <td class="py-3 px-4">
                                    <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold text-white" style="background-color: {{$cat.Color}}">{{$cat.Verdict}}</span>
                                </td>
                                <td class="py-3 px-4 text-gray-300">{{$cat.Description}}</td>
                            </tr>
                            {{end}}
                        </tbody>
                    </table>
                </div>
            </details>
        </section>

        <!-- Remediation Guidance -->
        <section id="remediation" class="mb-10 border-l-4 border-accent pl-4 sm:pl-6">
            <h2 class="text-xl sm:text-2xl font-semibold mb-6">Remediation Guidance</h2>
            <div class="remediation-content bg-navy-800 rounded-lg p-4 sm:p-6 prose prose-invert max-w-none
                        [&_h3]:text-base [&_h3]:sm:text-lg [&_h3]:font-semibold [&_h3]:text-gray-100 [&_h3]:mb-2
                        [&_h4]:text-sm [&_h4]:sm:text-base [&_h4]:font-semibold [&_h4]:text-gray-100 [&_h4]:mb-2
                        [&_p]:text-gray-300 [&_p]:mb-3
                        [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:mb-3
                        [&_li]:text-gray-300 [&_li]:mb-1
                        [&_strong]:text-gray-100">
                {{.SafeRemediation}}
            </div>
        </section>

        <!-- Pipeline Costs & Timing -->
        {{if .HasStepReports}}
        <section id="pipeline" class="mb-10 border-l-4 border-accent pl-4 sm:pl-6">
            <details>
                <summary class="text-xl sm:text-2xl font-semibold mb-6 hover:text-accent transition-colors">
                    Pipeline Costs &amp; Timing
                </summary>
                <div class="mt-4">
                    <!-- Desktop: table -->
                    <div class="hidden sm:block overflow-x-auto">
                        <table class="w-full text-sm">
                            <thead>
                                <tr class="border-b border-gray-700">
                                    <th class="text-left py-3 px-4 text-gray-300 font-medium">Step</th>
                                    <th class="text-left py-3 px-4 text-gray-300 font-medium">Duration</th>
                                    <th class="text-left py-3 px-4 text-gray-300 font-medium">Cost</th>
                                    <th class="text-left py-3 px-4 text-gray-300 font-medium">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                {{range $i, $step := .StepReports}}
                                <tr class="border-b border-gray-800 {{if even $i}}bg-navy-800/50{{else}}bg-navy-900/30{{end}}">
                                    <td class="py-3 px-4 font-mono">{{$step.Step}}</td>
                                    <td class="py-3 px-4">{{$step.Duration}}</td>
                                    <td class="py-3 px-4">{{$step.Cost}}</td>
                                    <td class="py-3 px-4 {{$step.StatusColor}}">{{$step.Status}}</td>
                                </tr>
                                {{end}}
                            </tbody>
                            <tfoot>
                                <tr class="border-t-2 border-gray-600 font-semibold text-gray-100">
                                    <td class="py-3 px-4">Total</td>
                                    <td class="py-3 px-4">{{.FormatDuration}}</td>
                                    <td class="py-3 px-4">{{.FormatTotalCost}}</td>
                                    <td class="py-3 px-4"></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                    <!-- Mobile: cards -->
                    <div class="sm:hidden space-y-3">
                        {{range .StepReports}}
                        <div class="bg-navy-800 rounded-lg p-4">
                            <div class="font-mono font-semibold text-gray-100 mb-2">{{.Step}}</div>
                            <div class="grid grid-cols-2 gap-2 text-sm">
                                <div>
                                    <span class="text-gray-400">Duration</span>
                                    <div class="text-gray-200">{{.Duration}}</div>
                                </div>
                                <div>
                                    <span class="text-gray-400">Cost</span>
                                    <div class="text-gray-200">{{.Cost}}</div>
                                </div>
                                <div>
                                    <span class="text-gray-400">Status</span>
                                    <div class="{{.StatusColor}}">{{.Status}}</div>
                                </div>
                            </div>
                        </div>
                        {{end}}
                        <div class="bg-navy-700 rounded-lg p-4 border-2 border-gray-600">
                            <div class="font-semibold text-gray-100 mb-2">Total</div>
                            <div class="grid grid-cols-2 gap-2 text-sm">
                                <div>
                                    <span class="text-gray-400">Duration</span>
                                    <div class="text-gray-100 font-semibold">{{.FormatDuration}}</div>
                                </div>
                                <div>
                                    <span class="text-gray-400">Cost</span>
                                    <div class="text-gray-100 font-semibold">{{.FormatTotalCost}}</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </details>
        </section>
        {{end}}

        <!-- All Findings (grouped by verdict) -->
        {{if .HasFindingGroups}}
        <section id="findings" class="mb-10 border-l-4 border-accent pl-4 sm:pl-6">
            <h2 class="text-xl sm:text-2xl font-semibold mb-6">All Findings</h2>
            <div class="space-y-4">
                {{range $g := .FindingsByVerdict}}
                <details{{if $g.OpenByDefault}} open{{end}} class="bg-navy-800 rounded-lg">
                    <summary class="flex items-center gap-3 px-4 sm:px-5 py-3 hover:bg-navy-700/50 rounded-lg transition-colors cursor-pointer">
                        <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold text-white capitalize" style="background-color: {{$g.VerdictColor}}">{{$g.Verdict}}</span>
                        <span class="text-gray-100 font-medium text-sm">{{$g.Count}} finding{{if ne $g.Count 1}}s{{end}}</span>
                    </summary>
                    <div class="px-4 sm:px-5 pb-4 pt-2 space-y-3">
                        {{range $f := $g.Findings}}
                        <details id="finding-{{$f.Number}}" class="bg-navy-900/50 border border-gray-700/50 rounded-lg group">
                            <summary class="flex flex-wrap items-center gap-2 sm:gap-3 px-4 sm:px-5 py-3 hover:bg-navy-700/50 rounded-lg transition-colors">
                                <span class="text-gray-400 text-xs font-mono font-medium w-8">#{{$f.Number}}</span>
                                {{if $f.HasDynamicTest}}
                                <span class="inline-block px-2 py-0.5 rounded text-[10px] font-semibold text-white" style="background-color: {{$f.DynamicTestColor}}">{{$f.DynamicTestStatus}}</span>
                                {{end}}
                                {{$url := $.FileURL $f.File}}{{if $url}}<a href="{{$url}}" target="_blank" rel="noopener" class="text-xs bg-navy-900 px-2 py-1 rounded text-accent hover:text-red-400 transition-colors" onclick="event.stopPropagation()">{{$f.File}}</a>{{else}}<code class="text-xs bg-navy-900 px-2 py-1 rounded text-gray-200">{{$f.File}}</code>{{end}}
                                <span class="font-mono text-xs text-gray-300">{{$f.Function}}</span>
                                {{if $f.AttackVector}}
                                <span class="text-xs text-gray-400 hidden sm:inline">— {{$f.AttackVector}}</span>
                                {{end}}
                            </summary>
                            <div class="px-4 sm:px-5 pb-4 pt-2 border-t border-gray-700/50">
                                {{if $f.AttackVector}}
                                <div class="mb-3 sm:hidden">
                                    <span class="text-gray-400 text-xs font-medium">Attack Vector</span>
                                    <p class="text-gray-300 text-sm mt-0.5">{{$f.AttackVector}}</p>
                                </div>
                                {{end}}
                                <div>
                                    <span class="text-gray-400 text-xs font-medium">Analysis</span>
                                    <p class="text-gray-300 text-sm mt-1 whitespace-pre-wrap leading-relaxed">{{$f.Analysis}}</p>
                                </div>
                                {{if $f.HasDynamicTest}}
                                <div class="mt-3 pt-3 border-t border-gray-700/30">
                                    <span class="text-gray-400 text-xs font-medium">Dynamic Test</span>
                                    <div class="flex items-center gap-2 mt-1">
                                        <span class="inline-block px-2 py-0.5 rounded text-xs font-semibold text-white" style="background-color: {{$f.DynamicTestColor}}">{{$f.DynamicTestStatus}}</span>
                                        {{if $f.DynamicTestDetails}}<span class="text-gray-400 text-xs">{{$f.DynamicTestDetails}}</span>{{end}}
                                    </div>
                                </div>
                                {{end}}
                            </div>
                        </details>
                        {{end}}
                    </div>
                </details>
                {{end}}
            </div>
        </section>
        {{end}}

        <!-- Footer -->
        <footer class="mt-10 sm:mt-12 pt-6 sm:pt-8 border-t border-gray-700 text-gray-500 text-xs sm:text-sm text-center">
            <p>Generated by <a href="https://knostic.ai" target="_blank" rel="noopener" class="text-accent font-semibold hover:text-red-400 transition-colors">OpenAnt</a></p>
        </footer>
    </main>

    <!-- Charts -->
    <script>
        Chart.register(ChartDataLabels);

        const chartOptions = {
            responsive: true,
            maintainAspectRatio: true,
            plugins: {
                legend: { display: false },
                datalabels: {
                    color: '#fff',
                    font: { weight: 'bold', size: 11 },
                    formatter: (value, ctx) => {
                        const total = ctx.chart.data.datasets[0].data.reduce((a, b) => a + b, 0);
                        const pct = Math.round((value / total) * 100);
                        if (pct < 5) return '';
                        return ctx.chart.data.labels[ctx.dataIndex] + '\n' + pct + '%';
                    },
                    textAlign: 'center'
                }
            }
        };

        new Chart(document.getElementById('unitChart'), {
            type: 'pie',
            data: {
                labels: {{toJSON .UnitChart.Labels}},
                datasets: [{
                    data: {{toJSON .UnitChart.Data}},
                    backgroundColor: {{toJSON .UnitChart.Colors}},
                    borderWidth: 2,
                    borderColor: '#16213e'
                }]
            },
            options: chartOptions
        });

        new Chart(document.getElementById('fileChart'), {
            type: 'pie',
            data: {
                labels: {{toJSON .FileChart.Labels}},
                datasets: [{
                    data: {{toJSON .FileChart.Data}},
                    backgroundColor: {{toJSON .FileChart.Colors}},
                    borderWidth: 2,
                    borderColor: '#16213e'
                }]
            },
            options: chartOptions
        });
    </script>
</body>
</html>
